# Dependencies
app/node_modules/

# Next.js build output
app/.next/
app/out/

# Local env (contains API keys + passwords)
app/.env.local
app/.env.*.local

# Database (runtime data, not source)
app/*.db
app/*.db-shm
app/*.db-wal

# Backups
app-backup-*/

# OS / editor
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# Claude Code local worktree scratch (git worktree metadata, not source)
.claude/

# Logs
*.log
npm-debug.log*

# Build artifacts
app/tsconfig.tsbuildinfo
app/.next/
