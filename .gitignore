# Dependencies
app/node_modules/

# Next.js build output
app/.next/
app/out/

# Local env (contains API keys + passwords)
app/.env.local
app/.env.*.local

# Database (runtime data, not source)
app/*.db
app/*.db-shm
app/*.db-wal

# Reference source copies and backups (read-only, not our code)
sources/
app-backup-*/

# OS / editor
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# Build artifacts
app/tsconfig.tsbuildinfo
app/.next/
