# Jellyfin (host network — use IP, not container name)
JELLYFIN_URL=http://192.168.0.50:8096
JELLYFIN_API_KEY=
# Required by Phase 3 availability poller — get from GET /Users/Me response field "Id"
JELLYFIN_USER_ID=

# Seerr
SEERR_URL=http://seerr:5055
SEERR_API_KEY=

# qBittorrent
QBIT_URL=http://qbittorrent:8080
QBIT_USERNAME=admin
QBIT_PASSWORD=

# App
NEXT_PUBLIC_APP_URL=https://unified.minijoe.dev

# Auth (required for production)
AUTH_SECRET=           # openssl rand -hex 32
ADMIN_USERNAME=akadmin
ADMIN_PASSWORD=        # Must meet password policy (see SETUP.md)

# Database
DB_PATH=./unified.db   # Dev path. Docker uses /data/unified.db via volume

# --- Independence Build (Phases 1–3) ---

# Phase 3: Seerr webhook verification (optional — leave blank in dev)
# If set, all POST /api/seerr/webhook requests must include X-Webhook-Signature: <this value>
# Configure the same value in Seerr → Settings → Notifications → Webhook → Secret
SEERR_WEBHOOK_SECRET=

# Phase 4: Subtitle management
# OpenSubtitles v3 API key — free tier: 5 downloads/day, VIP: $3/month for 1000/day
# Register at https://www.opensubtitles.com/en/consumers
OPENSUBTITLES_API_KEY=

# Comma-separated subtitle languages to download (default: en)
SUBTITLE_LANGUAGES=en

# Absolute path where media files are accessible inside the container
# Must be mounted as a Docker volume for subtitle sidecar files to be written
# Example: -v /data/media:/media  →  SUBTITLE_MEDIA_ROOT=/media
# Leave blank to disable file writing (subtitles logged but not saved to disk)
SUBTITLE_MEDIA_ROOT=

# --- Phase 5: Media Server (Jellyfin replacement, optional) ---

# TMDB API v3 Bearer token — required for metadata enrichment
# Get from https://www.themoviedb.org/settings/api → "API Read Access Token"
TMDB_ACCESS_TOKEN=

# Colon-separated list of media root directories to watch (inside the container)
# Example: /media/movies:/media/tv
# Mount matching Docker volumes so the container can read your actual media files
MEDIA_ROOTS=

# Directory for HLS transcode segments (temp storage — can be a tmpfs mount)
# Defaults to /tmp/transcode inside the container
TRANSCODE_CACHE=/tmp/transcode
